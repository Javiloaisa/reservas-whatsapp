# ============================================================
#  Agente WhatsApp - Clinica de podologia
#  Copia este archivo a `.env` y rellena los valores.
#  En desarrollo basta con poner ANTHROPIC_API_KEY; el resto
#  puede quedarse vacio (WhatsApp y Google Calendar arrancan
#  en "modo stub": registran en consola en vez de llamar a la API).
# ============================================================

# --- App ---
APP_BASE_URL=http://localhost:8000
SECRET_KEY=cambia-esto-por-una-cadena-larga-y-aleatoria
DATABASE_URL=sqlite:///./agente.db
# Produccion (ejemplo): postgresql+psycopg://user:pass@localhost/agente
TIMEZONE=Europe/Madrid
# DEBUG=true (dev): expone /docs y /dev/simulate y relaja los chequeos de arranque.
# EN PRODUCCION pon DEBUG=false (oculta /docs, desactiva /dev/simulate y exige
# un SECRET_KEY real). Generar SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(48))"
DEBUG=true

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
# Verificar el ID de modelo vigente; configurable sin tocar codigo.
CLAUDE_MODEL=claude-sonnet-4-6

# --- YCloud (coexistencia, proveedor preferente; vacio => modo stub) ---
# API key del panel de YCloud. Si se rellena, los envios van por YCloud.
YCLOUD_API_KEY=
# Token secreto para validar el webhook entrante (?token=... en la URL).
YCLOUD_WEBHOOK_SECRET=

# --- WhatsApp Cloud API de Meta (legado; dejar vacio => modo stub) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=token-inventado-para-validar-el-webhook
# App Secret de la app de Meta. Si se rellena, se valida la firma HMAC de cada
# webhook (X-Hub-Signature-256) y se rechazan los que no provengan de Meta.
# Muy recomendado en produccion.
WHATSAPP_APP_SECRET=
WHATSAPP_TEMPLATE_LANG=es
GRAPH_API_VERSION=v21.0

# --- Google Calendar (dejar vacio => modo stub) ---
GOOGLE_CREDENTIALS_FILE=
GOOGLE_CALENDAR_ID=

# --- Admin del panel (se usa en fases posteriores; el seed crea este usuario) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=cambia-esta-contrasena
