# ============================================================
#  Agente WhatsApp - Clinica de podologia
#  Copia este archivo a `.env` y rellena los valores.
#  En desarrollo basta con poner ANTHROPIC_API_KEY; el resto
#  puede quedarse vacio (WhatsApp y Google Calendar arrancan
#  en "modo stub": registran en consola en vez de llamar a la API).
# ============================================================

# --- App ---
APP_BASE_URL=http://localhost:8000
SECRET_KEY=cambia-esto-por-una-cadena-larga-y-aleatoria
DATABASE_URL=sqlite:///./agente.db
# Produccion (ejemplo): postgresql+psycopg://user:pass@localhost/agente
TIMEZONE=Europe/Madrid

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
# Verificar el ID de modelo vigente; configurable sin tocar codigo.
CLAUDE_MODEL=claude-sonnet-4-6

# --- WhatsApp Cloud API (dejar vacio => modo stub) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=token-inventado-para-validar-el-webhook
WHATSAPP_TEMPLATE_LANG=es
GRAPH_API_VERSION=v21.0

# --- Google Calendar (dejar vacio => modo stub) ---
GOOGLE_CREDENTIALS_FILE=
GOOGLE_CALENDAR_ID=

# --- Admin del panel (se usa en fases posteriores; el seed crea este usuario) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=cambia-esta-contrasena
