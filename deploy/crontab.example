# Avisos programados (§11 v2). Instalar con: crontab -u agente deploy/crontab.example
# Ajusta la ruta /opt/agente-podologo si despliegas en otro sitio.
#
# El servidor va en UTC y su cron no soporta CRON_TZ: el resumen se dispara a las
# 18:30 y 19:30 UTC y un guard deja pasar solo cuando son las 20:xx en Europe/Madrid
# (18:30 UTC en verano CEST, 19:30 UTC en invierno CET).

# Resumen de fin de dia al podologo: citas reservadas hoy (L-V a las 20:30 hora de Madrid).
30 18,19 * * 1-5 cd /opt/agente-podologo && [ "$(TZ=Europe/Madrid date +\%H)" = "20" ] && ./venv/bin/python -m scripts.resumen_diario >> /opt/agente-podologo/cron.log 2>&1

# Recordatorio 24 h (cada hora; idempotente, solo avisa a las citas en la ventana 23-25 h).
0 * * * * cd /opt/agente-podologo && ./venv/bin/python -m scripts.recordatorios >> /opt/agente-podologo/cron.log 2>&1

# Purga RGPD de mensajes/log_sombra (§14 v2; mensual, dia 1 a las 03:00 UTC).
0 3 1 * * cd /opt/agente-podologo && ./venv/bin/python -m scripts.purgar_mensajes >> /opt/agente-podologo/cron.log 2>&1
